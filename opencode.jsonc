{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "openwork",
  "instructions": [
    ".opencode/soul.md"
  ],
  "mcp": {
    "control-chrome": {
      "command": [
        "chrome-devtools-mcp"
      ],
      "type": "local"
    },
    "notion": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.notion.com/mcp",
      "oauth": {}
    },
    "context7": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.context7.com/mcp"
    }
  },
  "plugin": [
    "opencode-scheduler"
  ]
}
